{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlertEvent",
  "type": "object",
  "required": ["alert_id", "user_id", "risk_score", "reason", "timestamp", "triggering_events"],
  "properties": {
    "alert_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": { "type": "string" },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium"
    },
    "reason": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "triggering_events": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs or references to original security events"
    },
    "rule_name": { "type": "string" }
  }
}